<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Galleries</title>
  <link rel="stylesheet" href="{{ '/styles/galleries.css' | url }}" />
</head>

<body>
  <div class="app">
    <!-- Sidebar -->
    <div class="sidebar">
      <div class="dots">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>

      <nav class="nav">
        <div class="section-label">Favorites</div>

        <!-- Home -->
        <a class="item" href="{{ '/' | url }}">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 11l9-8 9 8"></path>
            <path d="M9 22V12h6v10"></path>
          </svg>
          <span>Home</span>
        </a>

        <!-- Wishlist -->
        <a class="item" href="{{ '/wishlist.html' | url }}">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M20.8 6.6a5.5 5.5 0 0 0-7.8 0L12 7.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 22l7.8-6.6 1-1a5.5 5.5 0 0 0 0-7.8z"></path>
          </svg>
          <span>Wishlist</span>
        </a>

        <!-- Galleries -->
        <a class="item" id="itemCurrent" href="{{ '/galleries.html' | url }}" aria-current="page">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 5h18v14H3z"></path>
            <circle cx="10" cy="10" r="2"></circle>
            <path d="M3 17l5-5 3 3 2-2 6 6"></path>
          </svg>
          <span>Galleries</span>
        </a>
      </nav>

      <!-- Folder navigation -->
      <div class="section-label">Folders</div>

      <div class="sidebarFolders">
        {% for wish in collections.all %}
          {% if wish.data.title and wish.url %}
            <a class="item" href="{{ wish.url | url }}" role="listitem">
              <svg class="icon folder" viewBox="0 0 25 25" fill="none" stroke="currentColor" stroke-width="2"
                   stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 7h6l2 3h10v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"></path>
              </svg>
              <span>{{ wish.data.title }}</span>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <!-- Image galleries -->
    <main class="content">
      <div class="topBar">
        <div class="topBarItem">
          <span>Locations</span>
          <span>›</span>
          <b>Galleries</b>
        </div>
      </div>

      <div class="image-grid-wrapper">
        <!-- First grid -->
        <div class="image-grid">
          {% for image in images %}
            {% if loop.index % 3 == 2 %}
              <img src="{{ image.url | url }}" alt="{{ image.alt or '' }}" loading="lazy">
            {% endif %}
          {% endfor %}
        </div>

        <!-- Second grid -->
        <div class="image-grid">
          {% for image in images %}
            {% if loop.index % 3 == 1 %}
              <img src="{{ image.url | url }}" alt="{{ image.alt or '' }}" loading="lazy">
            {% endif %}
          {% endfor %}
        </div>

        <!-- Third grid -->
        <div class="image-grid">
          {% for image in images %}
            {% if loop.index % 3 == 0 %}
              <img src="{{ image.url | url }}" alt="{{ image.alt or '' }}" loading="lazy">
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </main>
  </div>
</body>
</html>